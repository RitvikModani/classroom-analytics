# Copy to .env (which is gitignored). Secrets ONLY — tuning lives in config.yaml.

# RTSP camera with embedded credentials. This is a secret; never commit it.
# Overrides `source` in config.yaml when set.
# RTSP_URL=rtsp://user:pass@192.168.1.50:554/stream1

# Override the camera source without editing config.yaml (int index or path).
# CLASSROOM_SOURCE=0

# Override compute device: auto | intel:gpu | cpu
# CLASSROOM_DEVICE=intel:gpu
